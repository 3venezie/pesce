# Lordship-mongo connection (per the agentic-media two-tier brain).
# Set in the publisher's sandbox via /shared/.runtime/credentials.env;
# CF Pages does NOT have it (no tailnet), and the prebuild step
# no-ops when this is unset, building against the committed cache.
# See agentic-media/control-center/schemas/overlord-brain.md
# §"Two-tier mongo architecture".
LORDSHIP_MONGO_URI=mongodb://root:<password>@agentic-media-lordship-mongo.tail74c072.ts.net:27017/agentic_media_lordship?authSource=admin
LORDSHIP_MONGO_DB=agentic_media_lordship
